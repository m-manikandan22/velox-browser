<Window x:Class="VeloxBrowser.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        MinWidth="320"
        Background="#1E1E2E">
    <Border Padding="28,24">
        <StackPanel>
            <TextBlock x:Name="DialogTitle" Text="Rename Profile" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                       Foreground="White" Margin="0,0,0,16"/>
            <TextBox x:Name="NameBox" FontFamily="Segoe UI" FontSize="13" Height="32" Padding="8,4"
                     Background="#2A2A3C" Foreground="White" BorderBrush="#4C4C6E" BorderThickness="1"
                     CaretBrush="White" KeyDown="NameBox_KeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Width="80" Height="32" Margin="0,0,10,0" IsCancel="True"
                        Background="#2A2A3C" Foreground="White" BorderThickness="0" FontFamily="Segoe UI" Cursor="Hand"/>
                <Button x:Name="OkButton" Content="Rename" Width="80" Height="32" IsDefault="True"
                        Background="#2563EB" Foreground="White" BorderThickness="0" FontFamily="Segoe UI" Cursor="Hand"
                        Click="Rename_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
