<Window x:Class="VeloxBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="VeloxWindow"
        Title="Velox Browser"
        Icon="velox-logo.ico"
        Height="760" Width="1200"
        MinHeight="480" MinWidth="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        KeyDown="Window_KeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Tab Item Style in the Title Bar -->
        <Style x:Key="TabListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="10,0,4,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,4,2,0"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="MaxWidth" Value="240"/>
            <Setter Property="Width" Value="{Binding TabWidth, ElementName=VeloxWindow}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter TargetName="Bd" Property="Panel.ZIndex" Value="1"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TabTemplate">
            <Grid Focusable="False" Height="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Favicon: wrapped in a slight background so white/transparent favicons are visible -->
                <Grid Grid.Column="0" Margin="0,0,6,0">
                    <Border Width="16" Height="16" CornerRadius="8" Background="#F0F0F0"
                            Visibility="{Binding ElementName=FaviconImg, Path=Visibility}"/>
                    <Image x:Name="FaviconImg"
                           Width="12" Height="12"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding FaviconImage}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FaviconImage}" Value="{x:Null}">
                                        <!-- show nothing when no favicon -->
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
                <!-- Tab title -->
                <TextBlock Grid.Column="1" Text="{Binding Title, FallbackValue='New Tab'}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" FontSize="12" FontFamily="Segoe UI"
                           ToolTip="{Binding Title}"/>
                <!-- Close button -->
                <Button Grid.Column="2" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                        FontSize="8" Width="18" Height="18"
                        Margin="4,0,0,0" ToolTip="Close Tab"
                        Background="Transparent" BorderThickness="0"
                        Click="CloseTabButton_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{x:Static ApplicationCommands.New}" CommandParameter="incognito"/>
        <KeyBinding Gesture="Ctrl+T" Command="{x:Static ApplicationCommands.New}" CommandParameter="tab"/>
        <KeyBinding Gesture="Ctrl+W" Command="{x:Static ApplicationCommands.Close}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="NewCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Close}" Executed="CloseCommand_Executed"/>
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition x:Name="ToolbarRow" Height="52"/>
            <RowDefinition x:Name="ProgressRow" Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="StatusBarRow" Height="24"/>
        </Grid.RowDefinitions>

        <!-- Title Bar / Tab Strip -->
        <Grid Grid.Row="0"
              Background="{DynamicResource SurfaceBrush}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
              MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
              MouseMove="TitleBar_MouseMove"
              x:Name="TitleBar">
            <Grid.ColumnDefinitions>
                <!-- App dot icon -->
                <ColumnDefinition Width="Auto"/>
                <!-- Tabs + Add Tab (fills remaining space) -->
                <ColumnDefinition Width="*"/>
                <!-- Window Min/Max/Close controls (reserved, never overlaps) -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Logo -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="10,0,8,0">
                <Image Source="velox-logo.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>

            <!-- Tab strips: Tabs shrink proportionally via code-behind.
                 TabScrollViewer MaxWidth is constrained so AddTab bounds against it. -->
            <Grid Grid.Column="1" x:Name="TabAreaGrid" SizeChanged="TabArea_SizeChanged" Background="Transparent" VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <ScrollViewer x:Name="TabScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="TabStrip_PreviewMouseWheel"
                                  Style="{x:Null}">
                        <ListBox x:Name="TabStrip"
                                 Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource TabListBoxItemStyle}"
                                 ItemTemplate="{StaticResource TabTemplate}"
                                 SelectionChanged="TabStrip_SelectionChanged"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="TabStrip_PreviewMouseMove"
                                 Drop="TabStrip_Drop"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                    </ScrollViewer>
                    <Button x:Name="AddTabButton"
                            Content="&#xE710;"
                            Style="{StaticResource ChromeButtonStyle}"
                            Width="30" Height="30" Margin="2,0,0,1"
                            ToolTip="New Tab (Ctrl+T)"
                            Click="AddTabButton_Click"
                            VerticalAlignment="Bottom"/>
                </StackPanel>
            </Grid>

            <!-- Window Controls — in their own reserved column, never overlaps tabs -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Top" HorizontalAlignment="Right">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource ChromeButtonStyle}"
                        Content="&#xE921;" ToolTip="Minimize"
                        Click="MinimizeButton_Click"/>
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource ChromeButtonStyle}"
                        Content="&#xE922;" ToolTip="Maximize"
                        Click="MaximizeButton_Click"/>
                <Button x:Name="CloseButton"
                        Style="{StaticResource CloseButtonStyle}"
                        Content="&#xE8BB;" ToolTip="Close"
                        Click="CloseButton_Click"/>
            </StackPanel>

            <Border Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom"
                    Background="{DynamicResource BorderBrush}"/>
        </Grid>

        <!-- Navigation Toolbar -->
        <Grid Grid.Row="1"
              Background="{DynamicResource BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="BackButton" Style="{StaticResource NavButtonStyle}" Content="&#xE830;" Width="36" Height="36" ToolTip="Back (Alt+Left)" IsEnabled="False" Click="BackButton_Click" Margin="4,0,2,0"/>
            <Button Grid.Column="1" x:Name="ForwardButton" Style="{StaticResource NavButtonStyle}" Content="&#xEA47;" Width="36" Height="36" ToolTip="Forward (Alt+Right)" IsEnabled="False" Click="ForwardButton_Click" Margin="0,0,2,0"/>
            <Button Grid.Column="2" x:Name="RefreshButton" Style="{StaticResource NavButtonStyle}" Content="&#xE72C;" Width="36" Height="36" ToolTip="Refresh (F5)" Click="RefreshButton_Click" Margin="0,0,2,0"/>
            <Button Grid.Column="3" x:Name="HomeButton" Style="{StaticResource NavButtonStyle}" Content="&#xE80F;" Width="36" Height="36" ToolTip="Home" Click="HomeButton_Click" Margin="0,0,6,0"/>

            <!-- Address Bar with Autocomplete popup -->
            <Grid Grid.Column="4" Margin="0,8" VerticalAlignment="Stretch">
                <TextBox x:Name="AddressBar" Style="{StaticResource AddressBarStyle}"
                         Height="36" VerticalAlignment="Center" HorizontalAlignment="Stretch"
                         KeyDown="AddressBar_KeyDown"
                         GotFocus="AddressBar_GotFocus"
                         LostFocus="AddressBar_LostFocus"
                         TextChanged="AddressBar_TextChanged"
                         Tag="Search or enter address"/>
                <!-- Autocomplete dropdown -->
                <Popup x:Name="AutocompletePopup"
                       PlacementTarget="{Binding ElementName=AddressBar}"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       StaysOpen="False">
                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            MinWidth="400" MaxHeight="250"
                            Margin="0,2,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" Opacity="0.15" ShadowDepth="4"/>
                        </Border.Effect>
                        <ListBox x:Name="SuggestionList"
                                 Background="Transparent" BorderThickness="0"
                                 MouseUp="SuggestionList_MouseUp"
                                 KeyDown="SuggestionList_KeyDown">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>

            <!-- Profile avatar: shows Google profile picture or initials -->
            <Button Grid.Column="5" x:Name="ProfileButton" Margin="4,0,2,0"
                    Width="34" Height="34" BorderThickness="0" Background="Transparent"
                    ToolTip="Current Profile" Click="ShowProfiles_Click" Cursor="Hand">
                <Grid Width="28" Height="28">
                    <!-- Initials fallback (shown when no profile image) -->
                    <Border x:Name="ProfileInitialsBorder" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}">
                        <TextBlock x:Name="ProfileButtonText" Foreground="White" FontWeight="Bold" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Text="P"/>
                    </Border>
                    <!-- Actual profile image (hidden when null) -->
                    <Border x:Name="ProfileImageBorder" Width="28" Height="28" CornerRadius="14"
                            Visibility="Collapsed">
                        <Border.Background>
                            <ImageBrush x:Name="ProfileImageBrush" Stretch="UniformToFill"
                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border.Background>
                    </Border>
                </Grid>
            </Button>

            <Button Grid.Column="6" x:Name="MenuButton" Style="{StaticResource NavButtonStyle}" Content="&#xE712;" Width="36" Height="36" ToolTip="Menu" Click="MenuButton_Click" Margin="0,0,4,0">
                <Button.ContextMenu>
                    <ContextMenu x:Name="AppMenu">
                        <MenuItem Header="New tab" InputGestureText="Ctrl+T" Click="AddTabButton_Click"/>
                        <MenuItem Header="New incognito tab" InputGestureText="Ctrl+Shift+N" Click="NewIncognitoTab_Click"/>
                        <MenuItem Header="New window" InputGestureText="Ctrl+N" Click="NewWindow_Click"/>
                        <Separator/>
                        <MenuItem Header="History" InputGestureText="Ctrl+H" Click="History_Click"/>
                        <MenuItem Header="Downloads" InputGestureText="Ctrl+J" Click="Downloads_Click"/>
                        <MenuItem Header="Show Bookmarks" InputGestureText="Ctrl+B" Click="ShowBookmarks_Click"/>
                        <MenuItem Header="Bookmark this page" InputGestureText="Ctrl+D" Click="AddBookmark_Click"/>
                        <Separator/>
                        <MenuItem Header="Zoom">
                            <MenuItem Header="Zoom In" InputGestureText="Ctrl++" Click="ZoomIn_Click"/>
                            <MenuItem Header="Zoom Out" InputGestureText="Ctrl+-" Click="ZoomOut_Click"/>
                            <MenuItem Header="Reset" InputGestureText="Ctrl+0" Click="ZoomReset_Click"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Print..." InputGestureText="Ctrl+P" Click="Print_Click"/>
                        <MenuItem Header="Find..." InputGestureText="Ctrl+F" Click="Find_Click"/>
                        <MenuItem Header="More tools">
                            <MenuItem Header="Developer tools" InputGestureText="Ctrl+Shift+I" Click="DevTools_Click"/>
                        </MenuItem>
                        <MenuItem Header="Settings" Click="Settings_Click"/>
                        <MenuItem Header="Profiles" Click="ShowProfiles_Click"/>
                        <MenuItem Header="Clear Cache" Click="ClearCache_Click"/>
                        <MenuItem Header="Help" Click="Help_Click"/>
                        <Separator/>
                        <MenuItem Header="Exit" Click="Exit_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- Progress Bar -->
        <Border Grid.Row="2" Background="{DynamicResource BorderBrush}">
            <ProgressBar x:Name="LoadingProgress" IsIndeterminate="True" Height="3" Foreground="{DynamicResource AccentBrush}" Background="Transparent" BorderThickness="0" Visibility="Collapsed"/>
        </Border>

        <!-- Browser Container (Holds Multiple WebView2 controls dynamically) -->
        <Grid Grid.Row="3" x:Name="BrowserContainer" Background="{DynamicResource BackgroundBrush}">
        </Grid>
        
        <!-- Overlays (Moved outside BrowserContainer to prevent Z-Index/HitTest blocking) -->
        <Grid Grid.Row="3" x:Name="ErrorOverlay" Visibility="Collapsed" Background="{DynamicResource BackgroundBrush}" Panel.ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
                <TextBlock Text="&#xE814;" FontFamily="Segoe MDL2 Assets" FontSize="56" Foreground="{DynamicResource BorderBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Page can't be reached" FontFamily="Segoe UI" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="ErrorMessage" Text="" FontFamily="Segoe UI" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,24"/>
                <Button x:Name="RetryButton" Content="Try Again" Click="RetryButton_Click" HorizontalAlignment="Center" Padding="24,10" FontFamily="Segoe UI" FontSize="13" FontWeight="Medium" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
        
        <!-- Settings Overlay -->
        <Grid Grid.Row="3" x:Name="SettingsOverlay" Visibility="Collapsed" Background="#D9000000" Panel.ZIndex="1000">
            <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="12" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <TextBlock Text="Default Search Engine" FontWeight="SemiBold" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox x:Name="SearchEngineCombo" Margin="0,0,0,16" Height="30">
                        <ComboBoxItem Content="Google" Tag="https://www.google.com/search?q="/>
                        <ComboBoxItem Content="Bing" Tag="https://www.bing.com/search?q="/>
                        <ComboBoxItem Content="DuckDuckGo" Tag="https://duckduckgo.com/?q="/>
                    </ComboBox>

                    <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox x:Name="ThemeCombo" Margin="0,0,0,24" Height="30">
                        <ComboBoxItem Content="Light" Tag="Light"/>
                        <ComboBoxItem Content="Dark" Tag="Dark"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="CloseSettings_Click" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button Content="Save" Click="SaveSettings_Click" Padding="16,8" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- History Overlay -->
        <Grid Grid.Row="3" x:Name="HistoryOverlay" Visibility="Collapsed" Background="#D9000000" Panel.ZIndex="1000">
            <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="12" Width="600" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="History" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ListView x:Name="HistoryList" Grid.Row="1" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="0,0,0,16" MouseDoubleClick="HistoryList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" Width="250" DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="URL" Width="200" DisplayMemberBinding="{Binding Url}"/>
                                <GridViewColumn Header="Time" Width="100" DisplayMemberBinding="{Binding VisitTime, StringFormat=g}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Clear History" Click="ClearHistory_Click" Padding="16,8" Margin="0,0,8,0" Background="{DynamicResource SurfaceBrush}" BorderThickness="0" Foreground="Red"/>
                        <Button Content="Close" Click="CloseHistory_Click" Padding="16,8" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Bookmarks Overlay -->
        <Grid Grid.Row="3" x:Name="BookmarksOverlay" Visibility="Collapsed" Background="#D9000000" Panel.ZIndex="1000">
            <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="12" Width="600" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Bookmarks" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ListView x:Name="BookmarksList" Grid.Row="1" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="0,0,0,16" MouseDoubleClick="BookmarksList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" Width="250" DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="URL" Width="300" DisplayMemberBinding="{Binding Url}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Close" Click="CloseBookmarks_Click" Padding="16,8" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Downloads Overlay -->
        <Grid Grid.Row="3" x:Name="DownloadsOverlay" Visibility="Collapsed" Background="#D9000000" Panel.ZIndex="1000">
            <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="12" Width="600" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Downloads" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ListView x:Name="DownloadsList" Grid.Row="1" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="0,0,0,16">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File" Width="250" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="Progress" Width="80" DisplayMemberBinding="{Binding PercentComplete, StringFormat={}{0}%}"/>
                                <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding State}"/>
                                <GridViewColumn Header="Actions" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Pause" Margin="0,0,4,0" Padding="8,4" 
                                                        Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                                        Visibility="{Binding CanPause, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Click="DownloadPause_Click"/>
                                                <Button Content="Resume" Margin="0,0,4,0" Padding="8,4" 
                                                        Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                                        Visibility="{Binding CanResume, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Click="DownloadResume_Click"/>
                                                <Button Content="Cancel" Padding="8,4" 
                                                        Background="{DynamicResource DangerBrush}" Foreground="White" BorderThickness="0"
                                                        Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Click="DownloadCancel_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Close" Click="CloseDownloads_Click" Padding="16,8" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Profiles Overlay -->
        <Grid Grid.Row="3" x:Name="ProfilesOverlay" Visibility="Collapsed" Background="#D9000000" Panel.ZIndex="1000">
            <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="12" Width="600" Height="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Browser Profiles" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="+ Add Profile" Click="CreateProfile_Click" Padding="12,6" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Height="28" FontFamily="Segoe UI" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <!-- Profile list with Rename button per row -->
                    <ListBox x:Name="ProfilesList" Grid.Row="1" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="0,0,0,16"
                             MouseDoubleClick="ProfilesList_MouseDoubleClick" SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Avatar circle with initials or Image -->
                                    <Grid Grid.Column="0" Width="30" Height="30" VerticalAlignment="Center">
                                        <Border CornerRadius="15" Background="{DynamicResource AccentBrush}" />
                                        <Border CornerRadius="15">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        <!-- Fallback letter if no image -->
                                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Text="{Binding Name, Converter={StaticResource InitialsConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AvatarUrl}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Name}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Text" Value="{Binding Name, StringFormat='{}{0} (Current)'}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Email, TargetNullValue='Local Profile'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Rename" Margin="8,0,4,0" Padding="10,4"
                                            Background="{DynamicResource SurfaceBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                            FontSize="11" VerticalAlignment="Center" Cursor="Hand"
                                            Click="RenameProfile_Click"/>
                                    <Button Grid.Column="3" Content="Switch" Margin="0,0,4,0" Padding="10,4"
                                            Background="{DynamicResource AccentBrush}" BorderThickness="0" Foreground="White"
                                            FontSize="11" VerticalAlignment="Center" Cursor="Hand"
                                            Click="SwitchProfileButton_Click"/>
                                    <Button Grid.Column="4" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                                            Margin="0,0,0,0" Padding="8,4" Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource DangerBrush}" FontSize="13" VerticalAlignment="Center" Cursor="Hand" ToolTip="Remove Profile"
                                            Click="RemoveProfile_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Close" Click="CloseProfiles_Click" Padding="16,8" Background="{DynamicResource SurfaceBrush}" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Startup Profile Selector — Full-screen overlay (shown when >1 profile exists) -->
        <Grid x:Name="StartupProfileSelectorOverlay" Grid.RowSpan="5" Visibility="Collapsed" Panel.ZIndex="9999"
              Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="{DynamicResource BackgroundBrush}" Opacity="0.9" x:Name="StartupCardBg" CornerRadius="16" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="48">
                <StackPanel Width="400">
                <!-- Header -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Image Source="velox-logo.png" Width="28" Height="28" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Velox" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Who's using Velox?" FontFamily="Segoe UI" FontSize="28" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <!-- Profile Cards -->
                <ListBox x:Name="StartupProfilesList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="12" Width="110" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Click="StartupProfileSelected_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="12" Padding="16,18">
                                                        <ContentPresenter HorizontalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <Border CornerRadius="36" Background="{DynamicResource AccentBrush}" />
                                        <Border CornerRadius="36">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Text="{Binding Name, Converter={StaticResource InitialsConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AvatarUrl}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="{Binding Name}" FontFamily="Segoe UI" FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" Width="80" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding Email, TargetNullValue=''}" FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" Width="100" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Add Profile CTA -->
                <Button Content="+ Add profile" Margin="0,24,0,0" HorizontalAlignment="Center"
                        Padding="20,10" Background="{DynamicResource SurfaceBrush}" BorderThickness="1"
                        BorderBrush="{DynamicResource BorderBrush}" FontFamily="Segoe UI" FontSize="13"
                        Cursor="Hand" Click="StartupAddProfile_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock x:Name="StatusText" Text="Ready" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
